# Copia este archivo a backend/.env y completa con tus credenciales.
# NO COMMITEES backend/.env — contiene secretos.

# MongoDB Atlas (recomendado)
MONGO_CONNECTION_STRING=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/el_dorado?retryWrites=true&w=majority
MONGO_DB_NAME=el_dorado

# MongoDB local (alternativa)
#MONGO_HOST=localhost
#MONGO_PORT=27017
#MONGO_USER=change_me
#MONGO_PASS=change_me
#MONGO_DB_NAME=el_dorado
#MONGO_AUTH_DB=admin

# OCR (Windows: ruta al ejecutable de Tesseract)
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# Procesamiento
MIN_CONFIDENCE=0.5
DETECTION_COOLDOWN=5

# Almacenamiento
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE=10485760

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS (lista separada por comas de orígenes permitidos)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
